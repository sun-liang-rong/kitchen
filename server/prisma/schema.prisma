generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoupleStatus {
  ACTIVE
  UNBOUND
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
  USED
  EXPIRED
  CANCELLED
}

enum WishType {
  DISH
  FEELING
}

enum DesiredTime {
  TONIGHT
  TOMORROW
  THIS_WEEK
  WEEKEND
  SOMEDAY
}

enum WishIntensity {
  CASUAL
  THIS_WEEK
  TODAY
  VERY_TODAY
  WEEKEND_PLAN
}

enum SubstituteOption {
  SIMILAR_OK
  LIGHT_VERSION_OK
  WHAT_WE_HAVE_OK
  NO_SUBSTITUTE
}

enum WishStatus {
  IN_POOL
  PENDING_CONFIRMATION
  CLAIMED
  DEFERRED
  TOGETHER
  SHELVED
  FULFILLED
}

enum WishResponseType {
  FULFILL_TONIGHT
  LIGHT_VERSION
  ALTERNATIVE
  DEFER
  TOGETHER
  SHELVE
}

enum KitchenStatusValue {
  SERIOUS_COOK
  NORMAL
  TIRED
  SIMPLE_ONLY
  NO_COOKING
  COOK_TOGETHER
}

enum DishDifficulty {
  EASY
  NORMAL
  HARD
}

enum NotificationType {
  WISH_CREATED
  WISH_RESPONDED
  WISH_CLAIMED
  WISH_DEFERRED
  WISH_FULFILLED
}

enum UserGender {
  MALE
  FEMALE
  UNSPECIFIED
}

model User {
  id                   String          @id @default(uuid())
  nickname             String
  email                String?         @unique
  phone                String?         @unique
  passwordHash         String?         @map("password_hash")
  avatarUrl            String?         @map("avatar_url")
  gender               UserGender      @default(UNSPECIFIED)
  defaultKitchenStatus KitchenStatusValue? @map("default_kitchen_status")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  coupleAsA            Couple[]        @relation("CoupleUserA")
  coupleAsB            Couple[]        @relation("CoupleUserB")
  invites              CoupleInvite[]  @relation("InviteOwner")
  wishes               Wish[]          @relation("WishCreator")
  responses            WishResponse[]  @relation("WishResponder")
  fulfillments         WishFulfillment[] @relation("WishFulfiller")
  kitchenStatuses      KitchenStatus[]
  notifications        Notification[]

  @@map("users")
}

model Couple {
  id          String       @id @default(uuid())
  userAId     String       @map("user_a_id")
  userBId     String       @map("user_b_id")
  status      CoupleStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  userA       User         @relation("CoupleUserA", fields: [userAId], references: [id])
  userB       User         @relation("CoupleUserB", fields: [userBId], references: [id])
  wishes      Wish[]
  dishes      Dish[]

  @@index([userAId])
  @@index([userBId])
  @@map("couples")
}

model CoupleInvite {
  id         String       @id @default(uuid())
  inviterId String       @map("inviter_id")
  inviteeId String?      @map("invitee_id")
  coupleId  String?      @map("couple_id")
  code       String       @unique
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime     @map("expires_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  respondedAt DateTime?   @map("responded_at")

  inviter    User         @relation("InviteOwner", fields: [inviterId], references: [id])

  @@index([inviterId])
  @@index([inviteeId])
  @@index([coupleId])
  @@map("couple_invites")
}

model Wish {
  id                String             @id @default(uuid())
  coupleId          String             @map("couple_id")
  creatorId         String             @map("creator_id")
  title             String
  wishType          WishType           @map("wish_type")
  feelingTags       String[]           @map("feeling_tags")
  desiredTime       DesiredTime?       @map("desired_time")
  intensity         WishIntensity
  substituteOption  SubstituteOption?  @map("substitute_option")
  helperTasks       String[]           @map("helper_tasks")
  status            WishStatus         @default(IN_POOL)
  currentResponseId String?            @unique @map("current_response_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  couple            Couple             @relation(fields: [coupleId], references: [id])
  creator           User               @relation("WishCreator", fields: [creatorId], references: [id])
  currentResponse   WishResponse?      @relation("CurrentWishResponse", fields: [currentResponseId], references: [id])
  responses         WishResponse[]     @relation("WishResponses")
  fulfillment       WishFulfillment?
  dishes            Dish[]

  @@index([coupleId, status])
  @@index([creatorId])
  @@map("wishes")
}

model WishResponse {
  id            String           @id @default(uuid())
  wishId        String           @map("wish_id")
  responderId   String           @map("responder_id")
  responseType  WishResponseType @map("response_type")
  proposedTitle String?          @map("proposed_title")
  proposedTime  DesiredTime?     @map("proposed_time")
  reasonTags    String[]         @map("reason_tags")
  reasonText    String?          @map("reason_text")
  confirmedAt   DateTime?        @map("confirmed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  wish          Wish             @relation("WishResponses", fields: [wishId], references: [id])
  currentFor    Wish?            @relation("CurrentWishResponse")
  responder     User             @relation("WishResponder", fields: [responderId], references: [id])

  @@index([wishId])
  @@index([responderId])
  @@map("wish_responses")
}

model WishFulfillment {
  id              String   @id @default(uuid())
  wishId          String   @unique @map("wish_id")
  fulfillerId     String   @map("fulfiller_id")
  actualDishName  String   @map("actual_dish_name")
  helperTasksDone String[] @map("helper_tasks_done")
  feedbackTags    String[] @map("feedback_tags")
  note            String?
  addToDishes     Boolean  @default(false) @map("add_to_dishes")
  createdAt       DateTime @default(now()) @map("created_at")

  wish            Wish     @relation(fields: [wishId], references: [id])
  fulfiller       User     @relation("WishFulfiller", fields: [fulfillerId], references: [id])

  @@index([fulfillerId])
  @@map("wish_fulfillments")
}

model KitchenStatus {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  status    KitchenStatusValue
  note      String?
  date      DateTime
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@map("kitchen_statuses")
}

model Dish {
  id               String         @id @default(uuid())
  coupleId         String         @map("couple_id")
  name             String
  cookOwner        String?        @map("cook_owner")
  suitableTimeTags String[]       @map("suitable_time_tags")
  difficulty       DishDifficulty?
  tasteTags        String[]       @map("taste_tags")
  isFavorite       Boolean        @default(false) @map("is_favorite")
  sourceWishId     String?        @map("source_wish_id")
  lastFeedback     String?        @map("last_feedback")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  couple           Couple         @relation(fields: [coupleId], references: [id])
  sourceWish       Wish?          @relation(fields: [sourceWishId], references: [id])

  @@index([coupleId])
  @@map("dishes")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  content   String
  relatedId String?          @map("related_id")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@map("notifications")
}
